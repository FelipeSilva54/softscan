{
  "expo": {
    "name": "softscan",
    "slug": "softscan",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/splash-icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.softscan.app"
    },
    "web": {
      "favicon": "./assets/splash-icon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Precisamos da câmera para escanear o código de barras ou QR Code."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/adaptive-icon.png",
          "imageWidth": 120,
          "resizeMode": "contain",
          "backgroundColor": "#F5F7F8"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "d5b3f968-50a4-4a77-a191-4df06a665d4a"
      }
    }
  }
}
